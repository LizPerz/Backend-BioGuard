# BioGuard API - Environment Variables
# Copy this file to .env and fill in your values

MONGODB_CONNECTION_STRING=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?appName=BioGuard
JWT_SECRET_KEY=<replace-with-a-strong-random-string-at-least-32-chars>
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
